<Window x:Class="TextLayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TextLayer.App.Controls"
        xmlns:services="clr-namespace:TextLayer.App.Services"
        Title="{Binding WindowTitle}"
        Width="1360"
        Height="860"
        MinWidth="980"
        MinHeight="680"
        AllowDrop="True"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="Assets/TextLayer.ico"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <Style x:Key="OcrLanguageComboItemStyle"
               TargetType="ComboBoxItem"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="IsEnabled" Value="{Binding IsEnabled}" />
        </Style>

        <DataTemplate x:Key="OcrLanguageOptionTemplate">
            <StackPanel x:Name="OcrLanguageOptionRoot">
                <TextBlock Text="{Binding Label}"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=Foreground}" />
                <TextBlock Margin="0,2,0,0"
                           FontSize="11"
                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ComboBoxItem}, Path=Foreground}"
                           Opacity="0.78"
                           Text="{Binding Description}"
                           Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter TargetName="OcrLanguageOptionRoot" Property="Opacity" Value="0.72" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <DockPanel LastChildFill="False">
                <WrapPanel DockPanel.Dock="Left"
                           VerticalAlignment="Center">
                    <Button Style="{StaticResource AccentToolbarButtonStyle}"
                            Command="{Binding OpenImageCommand}"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.OpenImage]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ReRecognizeCommand}"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.ReRecognize]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding CopyAllTextCommand}"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.CopyAllText]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ClearImageCommand}"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.Clear]}" />
                </WrapPanel>

                <WrapPanel DockPanel.Dock="Right"
                           VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="SettingsButton_OnClick"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.Settings]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="FitToWindowButton_OnClick"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.Fit]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="ActualSizeButton_OnClick"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.ActualSize]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="ResetViewButton_OnClick"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.ResetView]}" />
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ToggleSidePanelCommand}"
                            Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.TextPanel]}" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="1"
                   Margin="16"
                   LastChildFill="True">
            <Border DockPanel.Dock="Left"
                    Width="320"
                    Margin="0,0,16,0"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18">
                        <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.ControlCenter]}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[ControlCenter.Description]}"
                                   TextWrapping="Wrap" />

                        <Border Margin="0,18,0,0"
                                Padding="14"
                                Background="{DynamicResource AccentSubtleBrush}"
                                CornerRadius="14">
                            <StackPanel>
                                <CheckBox IsChecked="{Binding IsOverlayEnabled}"
                                          FontWeight="SemiBold"
                                          Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[ControlCenter.EnableOverlay]}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="{Binding OverlayStatusText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <CheckBox Margin="0,18,0,0"
                                  IsChecked="{Binding CloseToTrayOnCloseSetting}"
                                  Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[ControlCenter.CloseToTray]}" />

                        <TextBlock Margin="0,20,0,8"
                                   Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.OcrEngine]}"
                                   FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding QuickOcrModeOptions}"
                                  DisplayMemberPath="Label"
                                  SelectedItem="{Binding SelectedQuickOcrMode}" />

                        <TextBlock Margin="0,16,0,8"
                                   Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.OcrLanguage]}"
                                   FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding QuickOcrLanguageOptions}"
                                  SelectedItem="{Binding SelectedQuickOcrLanguage}"
                                  ItemContainerStyle="{StaticResource OcrLanguageComboItemStyle}"
                                  ItemTemplate="{StaticResource OcrLanguageOptionTemplate}" />
                        <Border Margin="0,10,0,0"
                                Padding="10,8"
                                Background="{DynamicResource AccentSubtleBrush}"
                                CornerRadius="12">
                            <TextBlock Text="{Binding OcrRecommendationText}"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[ControlCenter.OcrLanguageHelper]}"
                                   TextWrapping="Wrap" />

                        <Button Margin="0,22,0,0"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="SettingsButton_OnClick"
                                Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.OpenSettings]}" />
                        <Button Margin="0,10,0,0"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Click="ExitButton_OnClick"
                                Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.ExitApp]}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border DockPanel.Dock="Right"
                    Width="372"
                    Margin="16,0,0,0"
                    Visibility="{Binding IsSidePanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Margin="16,16,16,12">
                        <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.RecognizedText]}"
                                   FontSize="18"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.RecognizedTextDescription]}"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             Margin="16,0,16,16"
                             Background="{DynamicResource EditorBrush}"
                             BorderBrush="{DynamicResource PanelBorderBrush}"
                             Foreground="{DynamicResource ForegroundBrush}"
                             Text="{Binding RecognizedText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled" />
                </Grid>
            </Border>

            <Border Background="{DynamicResource ViewerSurfaceBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <controls:ImageViewerControl x:Name="Viewer"
                                                 DisplayImageSource="{Binding DisplayImage}"
                                                 Document="{Binding CurrentDocument}"
                                                 ShowDebugBounds="{Binding ShowDebugBoundsOverlay}" />

                    <Border Visibility="{Binding IsEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#EAF7FAFF"
                            CornerRadius="18">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    MaxWidth="460">
                            <Border HorizontalAlignment="Center"
                                    Margin="0,0,0,18"
                                    Padding="10,4"
                                    Background="{DynamicResource AccentSubtleBrush}"
                                    CornerRadius="999">
                                <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.SecondaryViewer]}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{Binding StateTitle}"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center" />
                            <TextBlock Text="{Binding StateDescription}"
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <Button Width="190"
                                    Margin="0,22,0,0"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource AccentToolbarButtonStyle}"
                                    Command="{Binding OpenImageCommand}"
                                    Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.OpenImage]}" />
                            <Button Width="190"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="SettingsButton_OnClick"
                                    Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.OpenSettings]}" />
                        </StackPanel>
                    </Border>

                    <Border Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="#660B1220"
                            CornerRadius="18">
                        <Border Width="320"
                                Padding="20"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource PanelBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <StackPanel>
                                <TextBlock Text="{Binding StateTitle}"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding StateDescription}"
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           TextWrapping="Wrap" />
                                <ProgressBar Height="6"
                                             Margin="0,18,0,0"
                                             IsIndeterminate="True" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="16"
                            Padding="12,10"
                            Visibility="{Binding ShowStateBanner, Converter={StaticResource BoolToVisibilityConverter}}"
                            Background="{DynamicResource PanelBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel MaxWidth="340">
                            <TextBlock Text="{Binding StateTitle}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StateDescription}"
                                       Margin="0,4,0,0"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </DockPanel>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel LastChildFill="False">
                <TextBlock Text="{Binding StatusText}" />
                <TextBlock Text="{Binding HoverText}"
                           Margin="18,0,0,0"
                           Foreground="{DynamicResource SubtleTextBrush}" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding ZoomText}"
                           Foreground="{DynamicResource SubtleTextBrush}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
