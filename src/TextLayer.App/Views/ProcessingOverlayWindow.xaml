<Window x:Class="TextLayer.App.Views.ProcessingOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TextLayer.App.Services"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="False"
        Focusable="False">
    <Border Padding="14,12"
            Background="#D20D1524"
            BorderBrush="#663F8CFF"
            BorderThickness="1"
            CornerRadius="14">
        <StackPanel Orientation="Horizontal">
            <ProgressBar Width="56"
                         Height="6"
                         Margin="0,0,12,0"
                         VerticalAlignment="Center"
                         IsIndeterminate="True" />
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Processing.Title]}"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Processing.Description]}"
                           Margin="0,3,0,0"
                           Foreground="#D5E2FF"
                           FontSize="11" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
