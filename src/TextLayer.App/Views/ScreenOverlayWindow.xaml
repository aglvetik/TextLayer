<Window x:Class="TextLayer.App.Views.ScreenOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:TextLayer.App.Controls"
        xmlns:services="clr-namespace:TextLayer.App.Services"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowActivated="True"
        Focusable="True">
    <Window.Resources>
        <Style x:Key="OverlayActionButtonStyle"
               TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#EAF1FF" />
            <Setter Property="Background" Value="#2A6E8FFF" />
            <Setter Property="BorderBrush" Value="#5E8CCBFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#3A7FAFFF" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#86B6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#21587E" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="Transparent">
        <Border BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="6"
                Background="#01000000">
            <controls:ScreenOverlayControl x:Name="OverlayControl"
                                           Background="Transparent" />
        </Border>

        <Border x:Name="ActionBarBorder"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="12"
                Padding="10,7"
                Background="#D20D1524"
                BorderBrush="#553F8CFF"
                BorderThickness="1"
                CornerRadius="999"
                ClipToBounds="True"
                SnapsToDevicePixels="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Margin="0,0,8,0"
                        Padding="8,4"
                        Background="#223A4E73"
                        CornerRadius="999">
                    <TextBlock VerticalAlignment="Center"
                               Text="Esc"
                               Foreground="#D5E2FF"
                               FontSize="11"
                               FontWeight="SemiBold" />
                </Border>
                <Button x:Name="SelectAllButton"
                        Grid.Column="1"
                        Click="SelectAllButton_OnClick"
                        Style="{StaticResource OverlayActionButtonStyle}"
                        Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Overlay.Action.SelectAll]}" />
                <Button x:Name="CopyButton"
                        Grid.Column="2"
                        Click="CopyButton_OnClick"
                        Style="{StaticResource OverlayActionButtonStyle}"
                        Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Overlay.Action.Copy]}" />
                <Button Grid.Column="3"
                        Click="CloseButton_OnClick"
                        Margin="0"
                        Style="{StaticResource OverlayActionButtonStyle}"
                        Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Overlay.Action.Close]}" />
            </Grid>
        </Border>
    </Grid>
</Window>
