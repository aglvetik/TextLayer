<Window x:Class="TextLayer.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:TextLayer.App.Services"
        Title="{Binding Source={x:Static services:UiTextService.Instance}, Path=[About.Title]}"
        Width="420"
        Height="280"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="/Assets/TextLayer.ico"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Border Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="18">
            <StackPanel>
                <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[App.Name]}"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[About.Tagline]}"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource SubtleTextBrush}" />
                <TextBlock x:Name="VersionTextBlock"
                           Margin="0,14,0,0" />
                <TextBlock Margin="0,14,0,0"
                           Text="{Binding Source={x:Static services:UiTextService.Instance}, Path=[About.Description]}"
                           TextWrapping="Wrap" />
                <Button Margin="0,22,0,0"
                        Width="100"
                        HorizontalAlignment="Right"
                        Style="{StaticResource AccentToolbarButtonStyle}"
                        Click="CloseButton_OnClick"
                        Content="{Binding Source={x:Static services:UiTextService.Instance}, Path=[Common.Close]}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
